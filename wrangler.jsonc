{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "forme-studio",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // הדומיין המותאם (rmjewel.com + www) מנוהל ידנית ב-Cloudflare Dashboard
  // ולא כאן — Workers & Pages → forme-studio → Domains & Routes → Add →
  // Custom Domain. כך הדיפלוי לא צריך הרשאת Zone·Workers-Routes בטוקן (שכשלה
  // עם auth error 10000), ורץ עם הרשאות ה-account בלבד. Cloudflare מייצר את
  // רשומות ה-DNS + התעודות בעצמו, וההגדרה נשמרת בין דיפלויים.
  "observability": {
    "enabled": true
  }
  // Runtime secrets (set via `wrangler secret put` or the deploy workflow):
  //   ANTHROPIC_API_KEY, OPENAI_KEY, SUPABASE_URL, SUPABASE_SECRET_KEY,
  //   LLM_MODEL, OPENAI_MODEL, LLM_PROVIDER
  //   ADMIN_TOKEN — shared secret (>=8 chars) that gates /admin (site inquiries).
  //                 Without it, /admin is disabled; the public order form still works.
}
